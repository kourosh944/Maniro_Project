# نمونهٔ متغیرهای محیطی پروژهٔ مانیرو.
#
# برای development محلی: این فایل را کپی کرده و به نام backend/.env ذخیره
# کنید؛ اگر python-dotenv نصب باشد (requirements/development.txt)، به‌صورت
# خودکار توسط config/settings.py بارگذاری می‌شود. هرگز فایل .env واقعی
# (حاوی مقادیر واقعی) را commit نکنید — در .gitignore قرار دارد.
#
# برای production: این مقادیر باید به‌صورت متغیر محیطی واقعی روی سرور
# (systemd, Docker, پنل هاست و ...) تنظیم شوند، نه از طریق فایل .env.

# ------------------------------------------------------------------------
# هستهٔ Django
# ------------------------------------------------------------------------
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=maniro.ir,www.maniro.ir
DJANGO_CSRF_TRUSTED_ORIGINS=https://maniro.ir,https://www.maniro.ir
# مسیر پنل ادمین (اختیاری — پیش‌فرض admin/)
DJANGO_ADMIN_URL=admin/

# ------------------------------------------------------------------------
# دیتابیس (اختیاری — در صورت عدم تنظیم DJANGO_DB_ENGINE، SQLite استفاده می‌شود)
# ------------------------------------------------------------------------
DJANGO_DB_ENGINE=postgresql
DJANGO_DB_NAME=maniro
DJANGO_DB_USER=maniro
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432

# ------------------------------------------------------------------------
# ایمیل (برای اعلان پیام‌های فرم تماس)
# ------------------------------------------------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@maniro.ir
CONTACT_FORM_RECIPIENTS=admin@maniro.ir

# آدرس سایت — در لینک «برای مشاهده کلیک کنید» داخل ایمیل‌های اعلان استفاده می‌شود
SITE_URL=https://manirou.com

# مدیرانی که ایمیل خطای ۵۰۰ دریافت می‌کنند (فرمت name:email، جدا با کاما)
DJANGO_ADMINS=Admin:admin@maniro.ir

# ------------------------------------------------------------------------
# Cache / Rate limiting (اختیاری — بدون آن از LocMemCache استفاده می‌شود)
# ------------------------------------------------------------------------
DJANGO_REDIS_URL=

# ------------------------------------------------------------------------
# HTTPS / امنیت (فقط زمانی مؤثرند که DJANGO_DEBUG=False باشد)
# ------------------------------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# ------------------------------------------------------------------------
# لاگ
# ------------------------------------------------------------------------
DJANGO_LOG_LEVEL=INFO
